    {
      "parameters": {
        "promptType": "define",
        "text": "=下記漫画の構成をもとに各ページの画像を生成するプロンプトを作成してください ページ毎にプロンプトを配列形式で出力してほしいです レイアウトは漫画のように分割させてください 日本語のプロンプトにしてください\n\n{{ $json.content.parts[0].text }}\n\n出力例(それぞれの項目をYAML形式で出力してください)\nbase_manga\nYAML\n\nmanga_script:\n  format: \"全4ページ、ダイレクトメール広告漫画形式\"\n  page_format: \"漫画本B6判\"\n  aspect_ratio: \"約1:1.43\"\n\n  global_definitions:\n    art_style: \"学習教材の広告漫画スタイル、わかりやすく大げさな感情表現、明るい色彩、希望に満ちた雰囲気\"\n    setting:\n      location: \"放課後の教室\"\n      atmosphere: \"夕暮れ時、テスト返却後の悲喜こもごも\"\ncharacter\nYAML\n\ncharacters:\n  - id: \"kenta\"\n    name: \"健太\"\n    role: \"悩み多き主人公\"\n    appearance:\n      hair: \"短髪、少しボサボサ\"\n      eyes: \"今は絶望に染まっている\"\n      clothing: \"サッカー部のユニフォームまたは学生服。汗をかいている。全ページ共通\"\n  - id: \"daiki\"\n    name: \"大樹\"\n    role: \"成功した友人\"\n    appearance:\n      hair: \"爽やかなスポーツ刈り\"\n      eyes: \"自信に満ち溢れている\"\n      clothing: \"学生服、清潔感がある。片手にタブレット端末を持っている。全ページ共通\"\nprompt\nYAML\n\npanels:\n  - panel_number: 1\n    layout: \"ミディアムショット\"\n    visual_description: \"健太がテスト用紙を両手で持ち、頭を抱えて絶叫している。テスト用紙には赤字で『35点』と書かれている。背景に稲妻のエフェクト。\"\n    characters:\n      - id: \"kenta\"\n        action: \"テストを見て震える\"\n        expression: \"この世の終わりのような絶望顔\"\n    dialogue:\n      - speaker: \"kenta\"\n        text: \"うわあああ！ また赤点だ…！！\"\n      - speaker: \"kenta\"\n        text: \"部活が忙しくて勉強する時間なんてないよ～！ 母ちゃんに怒られる～！！\"\n  - panel_number: 2\n    layout: \"ツーショット\"\n    visual_description: \"大樹が涼しい顔で自分のテスト用紙（90点）をヒラヒラさせる。健太がそれを食い入るように見る。\"\n    characters:\n      - id: \"daiki\"\n        action: \"余裕の笑みでテストを見せる\"\n        expression: \"ドヤ顔だが爽やか\"\n      - id: \"kenta\"\n        action: \"大樹に詰め寄る\"\n        expression: \"驚愕と羨望\"\n    dialogue:\n      - speaker: \"daiki\"\n        text: \"俺は今回90点だったぜ。\"\n      - speaker: \"kenta\"\n        text: \"ええっ！？ 大樹、お前俺と同じで毎日遅くまで部活やってるじゃん！ なんで！？\"\n  - panel_number: 3\n    layout: \"クローズアップ\"\n    visual_description: \"大樹がババン！とタブレット端末（または赤ペンの入ったテキスト）を取り出す。背景にキラキラした集中線と『1日15分』の文字。\"\n    characters:\n      - id: \"daiki\"\n        action: \"教材をカメラ目線で突き出す\"\n        expression: \"自信満々のウィンク\"\n    dialogue:\n      - speaker: \"daiki\"\n        text: \"実は…これを使ってるんだ！\"\n      - speaker: \"daiki\"\n        text: \"『スキマ時間』にタブレットで要点だけ復習！ AIがニガテを分析してくれるから効率最強なんだ！\"\n      - speaker: \"kenta\"\n        text: \"そ、それなら俺にもできるかも…！？\"",
        "hasOutputParser": true,
        "options": {}
      },
